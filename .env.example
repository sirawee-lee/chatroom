# Firebase project config (Firebase Console → Project Settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# GIPHY API key (https://developers.giphy.com) — required for GIF picker
VITE_GIPHY_API_KEY=

# Google Gemini API key (https://aistudio.google.com) — required for AI chatbot
VITE_GEMINI_API_KEY=
